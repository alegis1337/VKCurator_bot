# ============================================================
# VK Curator Bot — пример переменных окружения
# Скопируйте в .env и заполните реальными значениями.
# .env НЕ коммитится в git (см. .gitignore).
# ============================================================

# === VK ===
# Токены сообществ через запятую (один или несколько). Каждое сообщество
# даёт лимит ~10 беседы (30 для верифицированных). Лимит ВК, не нашего кода.
VK_GROUP_TOKENS=
# Legacy: можно использовать одиночный VK_GROUP_TOKEN — будет работать как один бот
# VK_GROUP_TOKEN=

# (опционально, для справки)
VK_GROUP_ID=

# === PostgreSQL ===
# Используйте СИЛЬНЫЙ случайный пароль (минимум 24 символа).
# Сгенерировать: openssl rand -base64 32
# Для запуска под systemd с ProtectHome=tmpfs обязательно ?ssl=disable —
# иначе asyncpg падает на stat() дефолтного ~/.postgresql/postgresql.key
DATABASE_URL=postgresql+asyncpg://botuser:CHANGE_ME@localhost:5432/vk_curator_bot?ssl=disable

# === LLM (polza.ai, OpenAI-совместимый) ===
POLZA_API_KEY=
POLZA_BASE_URL=https://polza.ai/api/v1
POLZA_MODEL=deepseek-chat

# === Google Sheets ===
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
GOOGLE_SPREADSHEET_ID=

# === Авторизация ===
# Главный куратор — единственный, кто может выполнять /start /stop /status
HEAD_CURATOR_ID=

# Список ID кураторов (через запятую, без пробелов).
# Используется ТОЛЬКО для разметки ролей в саммари (куратор/ученик).
# Пример: CURATOR_IDS=123456,789012
CURATOR_IDS=

# === Расписание ===
SUMMARY_TIME=20:00
CLEANUP_TIME=03:00
MESSAGE_RETENTION_DAYS=30
TIMEZONE=Europe/Moscow

# === Уведомления о неотвеченных сообщениях ===
# VK ID получателя личных уведомлений (он должен предварительно сам написать
# одному из ботов, чтобы community мог ему отвечать).
ALERT_RECIPIENT_ID=
# Через сколько часов без ответа куратора отправлять уведомление
ALERT_THRESHOLD_HOURS=2
# Как часто проверять (в минутах). 0 — выключить.
ALERT_CHECK_INTERVAL_MIN=15
# Рабочие часы (часы дня в TIMEZONE). ВС — выходной по умолчанию.
WORK_HOURS_START=11
WORK_HOURS_END=19
